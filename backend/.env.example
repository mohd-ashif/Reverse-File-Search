ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/reverse_file_search

STORAGE_DIR=./storage
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=file_chunks


EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHUNK_SIZE_WORDS=500


CHUNK_OVERLAP_WORDS=50

# Leave blank to use tesseract from PATH, or set an absolute path to the executable

TESSERACT_CMD=

# Groq Cloud (https://console.groq.com) — used to synthesize a natural-language
# answer from search results. Leave blank to disable AI answers.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

SECRET_KEY=change-me-in-env
ACCESS_TOKEN_EXPIRE_MINUTES=1440 

BACKEND_CORS_ORIGINS=["http://localhost:5173"] 
